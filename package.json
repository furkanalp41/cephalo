{
  "name": "cephalo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cephalo — an octopus-themed, copy-paste-ready OSCP command-and-technique engine. Offline-first static SPA.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.18.1"
  },
  "scripts": {
    "dev": "pnpm build:content && vite",
    "build:content": "tsx scripts/build-content.ts",
    "build:v2": "tsx scripts/build-v2.ts",
    "build": "pnpm build:content && tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint .",
    "format": "prettier --write .",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:content-parity": "vitest run src/types/schema-parity",
    "test:e2e": "playwright test",
    "gate:fabrication": "tsx scripts/gate-fabrication.ts",
    "gate:routable-ip": "tsx scripts/gate-routable-ip.ts",
    "gate:placeholder": "tsx scripts/gate-placeholder.ts",
    "gate:credmode": "tsx scripts/gate-credmode.ts",
    "gate:side-table": "tsx scripts/gate-side-table.ts",
    "gate:overlap": "tsx scripts/gate-overlap.ts",
    "gate:denylist": "tsx scripts/gate-denylist.ts",
    "gate:tokens": "tsx scripts/gate-tokens.ts",
    "gate:coverage": "tsx scripts/gate-coverage.ts",
    "gate:unverified-refs": "tsx scripts/gate-unverified-refs.ts",
    "gate:tool-provenance": "tsx scripts/gate-tool-provenance.ts",
    "gate:advisor-coverage": "tsx scripts/gate-advisor-coverage.ts",
    "gate:intent-resolves": "tsx scripts/gate-intent-resolves.ts",
    "gate:decision-reachability": "tsx scripts/gate-decision-reachability.ts",
    "gate:nmap-route-coverage": "tsx scripts/gate-nmap-route-coverage.ts",
    "gate:no-ambient-clock": "tsx scripts/gate-no-ambient-clock.ts",
    "gate:cve-antifab": "tsx scripts/gate-cve-antifab.ts",
    "gate:unverified-citation": "tsx scripts/gate-unverified-citation.ts",
    "gate:no-ai-deps": "tsx scripts/gate-no-ai-deps.ts",
    "gate:no-runtime-net": "tsx scripts/gate-no-runtime-net.ts",
    "gate:csp": "tsx scripts/gate-csp.ts",
    "gate:pack-coverage": "tsx scripts/gate-pack-coverage.ts",
    "gate:osce3-cite": "tsx scripts/gate-osce3-cite.ts",
    "gate:evasion-methodology-only": "tsx scripts/gate-evasion-methodology-only.ts",
    "emit:heatmap": "tsx scripts/emit-heatmap.ts",
    "build:denylist-manifest": "tsx scripts/build-denylist-manifest.ts",
    "build:overlap-fingerprints": "tsx scripts/build-overlap-fingerprints.ts",
    "ci": "tsx scripts/ci.ts"
  },
  "dependencies": {
    "@rive-app/react-canvas": "^4.18.5",
    "@tanstack/react-router": "^1.95.6",
    "@xyflow/react": "^12.3.6",
    "dagre": "^0.8.5",
    "minisearch": "^7.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/dagre": "^0.7.52",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/sanitize-html": "^2.13.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^25.0.1",
    "marked": "^15.0.4",
    "prettier": "^3.4.2",
    "sanitize-html": "^2.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "workbox-window": "^7.3.0",
    "vitest": "^2.1.8",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  }
}
